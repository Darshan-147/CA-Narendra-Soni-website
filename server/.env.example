# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/ca_website

# Port the API server runs on
PORT=5000

# URL(s) of the React client, comma-separated if needed (used for CORS)
CLIENT_URL=http://localhost:5173,https://ca-narendra-soni-website.vercel.app

# Optional alias for extra allowed frontend origins
CORS_ORIGINS=
